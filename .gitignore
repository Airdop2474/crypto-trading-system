# .gitignore - 多人协作必备

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================
# Node
# ============================================
node_modules/

# ============================================
# 虚拟环境
# ============================================
venv/
ENV/
env/
.venv/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 测试
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============================================
# 敏感信息（重要！）
# ============================================
.env
.env.local
*.key
*.pem
secrets/
credentials/

# ============================================
# 数据文件
# ============================================
data/raw/
data/processed/
*.csv
*.parquet
*.db
*.sqlite
*.log

# ============================================
# 模型和缓存
# ============================================
*.pkl
*.pickle
*.h5
*.joblib
.cache/

# ============================================
# 文档构建
# ============================================
docs/_build/
site/

# ============================================
# 操作系统
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Jupyter Notebook
# ============================================
.ipynb_checkpoints/
*.ipynb

# ============================================
# 临时文件
# ============================================
tmp/
temp/
*.tmp
*.bak

# ============================================
# 项目特定
# ============================================
# 但保留示例文件
!.env.example
!data/.gitkeep
!logs/.gitkeep

# 回测结果（太大）
backtest_results/*.json
backtest_results/*.html

# 交易日志（敏感）
trading_logs/

# AI 模型（太大）
models/*.pth
models/*.onnx

# Claude Code 本地配置（每台机器专属，勿提交）
.claude/settings.local.json

# 一键启动脚本运行日志
start.log
start.err

# Paper Trading 守护进程运行时产物（每次运行专属，勿提交）
logs/
data/paper_daemon_state.json
data/paper_daemon_state.json.*
data/paper_daemon_state_*.json
data/paper_daemon_state_*.json.*
data/.emergency_stop
data/.risk_pause
data/.risk_resume
data/.risk_reset
data/reports/paper/daily/
data/_archive_*/

# Analyzer / Hermes 运行时产物
data/memory/
data/hermes_events/
data/portfolio_heat.json

# Binance 历史数据本地缓存（CSV 已被 *.csv 覆盖，整目录忽略含探索脚本）
data/Binance/

# 测试运行产物
data/reports/test/
data/reports/test_verify/
data/test_verify.json

# 误创建/临时产物
nul
tmp_diff_*.txt

# 工作助手记忆文件
.workbuddy/memory/

# 前端构建产物
frontend/tsconfig.tsbuildinfo

# Qoder IDE 本地配置
.qoder/

# Trae IDE 本地配置
.trae/

# 项目内 analyzer 记忆（运行时累积，不入库）
data/memory/

# Hermes 事件日志（运行时产物）
data/hermes_events/

# Binance 历史数据档案（大体积本地数据，不入库）
data/Binance/
