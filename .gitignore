# .gitignore - 多人协作必备

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================
# Node
# ============================================
node_modules/

# ============================================
# 虚拟环境
# ============================================
venv/
ENV/
env/
.venv/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 测试
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============================================
# 敏感信息（重要！）
# ============================================
.env
.env.local
*.key
*.pem
secrets/
credentials/

# ============================================
# 数据文件
# ============================================
data/raw/
data/processed/
*.csv
*.parquet
*.db
*.sqlite
*.log

# ============================================
# 模型和缓存
# ============================================
*.pkl
*.pickle
*.h5
*.joblib
.cache/

# ============================================
# 文档构建
# ============================================
docs/_build/
site/

# ============================================
# 操作系统
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Jupyter Notebook
# ============================================
.ipynb_checkpoints/
*.ipynb

# ============================================
# 临时文件
# ============================================
tmp/
temp/
*.tmp
*.bak

# ============================================
# 项目特定
# ============================================
# 但保留示例文件
!.env.example
!data/.gitkeep
!logs/.gitkeep

# 回测结果（太大）
backtest_results/*.json
backtest_results/*.html

# 交易日志（敏感）
trading_logs/

# AI 模型（太大）
models/*.pth
models/*.onnx

# Claude Code 本地配置（每台机器专属，勿提交）
.claude/settings.local.json
