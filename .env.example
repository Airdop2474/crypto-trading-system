# .env.example - 环境变量模板
# 复制此文件为 .env 并填入实际值
# ⚠️ 不要提交 .env 到 Git！

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_trading
REDIS_URL=redis://localhost:6379/0

# TimescaleDB 配置
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=your_secure_password
TIMESCALE_DATABASE=crypto_trading

# ============================================
# 交易所 API（测试网）
# ============================================
# Binance 测试网
BINANCE_API_KEY=your_testnet_api_key
BINANCE_SECRET=your_testnet_secret
BINANCE_TESTNET=true

# 其他交易所（可选）
# OKEX_API_KEY=
# OKEX_SECRET=
# OKEX_PASSWORD=

# ============================================
# 实盘控制（重要！）
# ============================================
# ⚠️ 默认必须是 false
LIVE_TRADING_ENABLED=false

# 实盘 API（只在 Phase 6+ 使用）
# BINANCE_LIVE_API_KEY=
# BINANCE_LIVE_SECRET=

# ============================================
# 风控参数
# ============================================
# 日亏损限制（Phase 1-5: 2%, Phase 6+: 3%）
MAX_DAILY_LOSS=0.02

# 单笔仓位限制
MAX_POSITION_SIZE=0.20

# 总仓位限制
MAX_TOTAL_POSITION=0.60

# 连续亏损熔断
MAX_CONSECUTIVE_LOSSES=5

# ============================================
# AI API
# ============================================
# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4

# Anthropic Claude（可选）
# ANTHROPIC_API_KEY=

# ============================================
# 监控和告警
# ============================================
# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# 告警通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=

# ============================================
# 应用配置
# ============================================
# 环境
ENVIRONMENT=development  # development, staging, production

# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# 时区
TIMEZONE=UTC

# ============================================
# Phase 特定配置
# ============================================
# Phase 1: 数据
DATA_START_DATE=2023-01-01
DATA_END_DATE=2024-12-31
DATA_SYMBOLS=BTC/USDT,ETH/USDT
DATA_TIMEFRAME=4h

# Phase 4: Paper Trading
PAPER_INITIAL_BALANCE=10000
PAPER_COMMISSION=0.001
PAPER_SLIPPAGE_BTC=0.0005
PAPER_SLIPPAGE_ETH=0.001

# ============================================
# 开发工具
# ============================================
# Debug 模式
DEBUG=false

# 自动重载
AUTO_RELOAD=true

# ============================================
# 注意事项
# ============================================
# 1. 复制此文件为 .env
# 2. 填入实际值
# 3. 不要提交 .env 到 Git
# 4. 定期更换 API Key
# 5. 实盘 API Key 必须限制权限（无提币）
