# ============================================
# ⚠️ SECURITY: Never commit real API keys here.
# Use environment variable injection or a secrets manager for production.
# All keys below are placeholders — replace with your own.
# ============================================
#
# .env.example - 环境变量模板
# 复制此文件为 .env 并填入实际值
# ⚠️ 不要提交 .env 到 Git！

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_trading
REDIS_URL=redis://:CHANGE_ME_NOW@localhost:6379/0

# TimescaleDB 配置
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=your_secure_password
TIMESCALE_DATABASE=crypto_trading

# ============================================
# 交易所 API（测试网）
# ============================================
# Binance 测试网
BINANCE_API_KEY=your_testnet_api_key
BINANCE_SECRET=your_testnet_secret
BINANCE_TESTNET=true
# Binance 反代 URL（美国 IP 被地域限制 451，用 Cloudflare Worker 中转）
# 留空=直连；填写如 https://binance-proxy.your-name.workers.dev
# 部署方法见 docs/BINANCE_PROXY_SETUP.md
BINANCE_PROXY_URL=

# 其他交易所（可选）
# OKEX_API_KEY=
# OKEX_SECRET=
# OKEX_PASSWORD=

# ============================================
# API 服务认证（必需！任何环境）
# ============================================
# ⚠️ 后端 API 强制要求：config.validate() 中空值触发 CRITICAL，未设置时 API 不可用。
# 设为一个随机字符串；前端 NEXT_PUBLIC_API_TOKEN 必须与此一致。
API_TOKEN=change-me-to-a-random-token

# ============================================
# 实盘控制（重要！）
# ============================================
# ⚠️ 默认必须是 false
LIVE_TRADING_ENABLED=false

# 实盘 API（只在 Phase 6+ 使用）
# BINANCE_LIVE_API_KEY=
# BINANCE_LIVE_SECRET=

# ============================================
# 风控参数
# ============================================
# 日亏损限制（Phase 1-5: 2%, Phase 6+: 3%）
MAX_DAILY_LOSS=0.02

# 单笔仓位限制
MAX_POSITION_SIZE=0.20

# 总仓位限制
MAX_TOTAL_POSITION=0.60

# 连续亏损熔断
MAX_CONSECUTIVE_LOSSES=5

# 账户级最大回撤（累计慢亏保护，默认 15%）
MAX_TOTAL_DRAWDOWN=0.15

# API 连续失败熔断阈值
MAX_API_FAILURES=3

# ============================================
# AI API（策略进化 LLM 解读，可选）
# ============================================
# 协议类型: openai (兼容 DeepSeek/智谱/Ollama 等) | anthropic | local (纯规则)
LLM_PROVIDER=

# API Key（统一配置，优先级高于下方旧变量）
LLM_API_KEY=

# 自定义 API 地址（留空使用官方默认地址）
# 示例：DeepSeek https://api.deepseek.com/v1
#       Ollama   http://localhost:11434/v1
#       智谱     https://open.bigmodel.cn/api/paas/v4
#       月之暗面 https://api.moonshot.cn/v1
LLM_BASE_URL=

# 模型名称（留空按协议选默认：openai->gpt-4o-mini，anthropic->claude-sonnet-4-20250514）
LLM_MODEL=

# --- 旧变量（向后兼容，仍可使用）---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 无 API Key 时自动回退本地规则解读，功能不受影响

# ============================================
# 监控和告警
# ============================================
# Grafana（Docker Compose 使用，Python 端不读取）
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_NOW

# PostgreSQL (Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_NOW
POSTGRES_DB=crypto_trading
POSTGRES_PORT=5432

# Redis (Docker Compose)
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_NOW

# 告警通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 最低通知级别: INFO / WARNING / CRITICAL（默认 INFO 接收全部）
TELEGRAM_MIN_LEVEL=INFO
# 磁盘告警阈值（百分比，默认 85，仅 monitor_disk.py 使用）
DISK_ALERT_THRESHOLD=85

# ============================================
# 应用配置
# ============================================
# 环境
ENVIRONMENT=development  # development, staging, production

# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# 日志文件目录（默认 logs/，仅 src/main.py 读取）
LOG_PATH=logs

# 运行模式（backtest / paper / daemon，仅 src/main.py 读取，留空走 API 服务）
MODE=

# SQLAlchemy SQL 回显（true/false，默认 false）
SQL_ECHO=false

# Hermes CLI 安装路径（可选，仅 agent/hermes_bridge/adapter.py 读取）
HERMES_HOME=
# Hermes 回调地址（生产部署设为实际域名，如 https://your-domain.com）
HERMES_CALLBACK_BASE_URL=http://localhost:8000

# 时区
TIMEZONE=UTC

# CORS 允许来源（逗号分隔）
# 开发默认放行 Next.js 3000/3001；生产必须收紧到实际域名
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Phase 特定配置
# ============================================
# Phase 1: 数据
DATA_START_DATE=2023-01-01
DATA_END_DATE=2024-12-31
DATA_SYMBOLS=BTC/USDT,ETH/USDT
DATA_TIMEFRAME=4h

# ============================================
# 开发工具
# ============================================
# Debug 模式
DEBUG=false

# ============================================
# 注意事项
# ============================================
# 1. 复制此文件为 .env
# 2. 填入实际值
# 3. 不要提交 .env 到 Git
# 4. 定期更换 API Key
# 5. 实盘 API Key 必须限制权限（无提币）
