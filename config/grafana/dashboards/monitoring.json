{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["crypto", "paper-trading", "phase5"],
  "time": { "from": "now-90d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Crypto Trading — Monitoring",
  "uid": "crypto-monitoring",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Total Account Value",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT timestamp AS \"time\", total_value FROM monitor_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 2,
      "title": "Current Return",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": -0.1 },
            { "color": "green", "value": 0 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT timestamp AS \"time\", total_return FROM monitor_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 3,
      "title": "Realized PnL",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT timestamp AS \"time\", realized_pnl FROM monitor_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Trades",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT timestamp AS \"time\", total_trades FROM monitor_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    },
    {
      "id": 5,
      "title": "Risk State (latest)",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "ACTIVE": { "color": "green", "index": 0 }, "PAUSED": { "color": "yellow", "index": 1 }, "STOPPED": { "color": "red", "index": 2 } } }
          ],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^risk_state$/", "values": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT risk_state FROM monitor_metrics ORDER BY timestamp DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 6,
      "title": "Consecutive Losses",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 40 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT timestamp AS \"time\", consecutive_losses FROM monitor_metrics WHERE $__timeFilter(timestamp) ORDER BY timestamp"
        }
      ]
    }
  ]
}
